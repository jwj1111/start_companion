# ============================================================
# START Companion 敏感凭据
# 复制为 .env 并填入真实值
#
# 变量名与 config.yaml 中 model_pool 各条目的 api_key_env / base_url_env 对应。
# 如果多个模型共用同一个 Key，让它们指向同一个变量名即可。
# ============================================================

# === 模型密钥 ===
# gpt4o
GPT4O_API_KEY=sk-xxx
GPT4O_BASE_URL=

# gpt4o_mini（如果和 gpt4o 共用 Key，可以写同一个值）
GPT4O_MINI_API_KEY=sk-xxx
GPT4O_MINI_BASE_URL=

# openai embedding
OPENAI_EMBED_API_KEY=sk-xxx
OPENAI_EMBED_BASE_URL=

# --- 按需添加 ---
# HUNYUAN_API_KEY=xxx
# HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
# DEEPSEEK_API_KEY=xxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# ANTHROPIC_API_KEY=sk-ant-xxx
# OLLAMA_URL=http://localhost:11434

# === 向量数据库 ===
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_API_KEY=

# === MySQL（正式环境）===
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ai_companion
MYSQL_USERNAME=root
MYSQL_PASSWORD=

# === 语音服务 ===
ASR_API_KEY=
ASR_BASE_URL=
TTS_API_KEY=
TTS_BASE_URL=

# === 联网搜索 ===
WEB_SEARCH_API_KEY=tvly-xxx
